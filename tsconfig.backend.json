{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "outDir": "./backend/dist",
    "rootDir": "./backend"
  },
  "include": ["backend/**/*.ts"]
}
